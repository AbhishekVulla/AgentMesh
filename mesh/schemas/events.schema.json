      "additionalProperties": false,
      "description": "Describes an agent in `mesh.session.started`.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "exposes": {
          "items": {
            "type": "string"
          },
          "title": "Exposes",
          "type": "array"
        }
      },
      "required": [
        "id",
        "role",
        "exposes"
      ],
      "title": "AgentDescriptor",
      "type": "object"
    },
    "AgentStateChanged": {
      "additionalProperties": false,
      "properties": {
        "seq": {
          "minimum": 0,
          "title": "Seq",
          "type": "integer"
        },
        "ts": {
          "title": "Ts",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "event": {
          "const": "agent.state.changed",
          "default": "agent.state.changed",
          "enum": [
            "agent.state.changed"
          ],
          "title": "Event",
          "type": "string"
        },
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "from": {
          "enum": [
            "IDLE",
            "WORKING",
            "BLOCKED",
            "COMPLETED"
          ],
          "title": "From",
          "type": "string"
        },
        "to": {
          "enum": [
            "IDLE",
            "WORKING",
            "BLOCKED",
            "COMPLETED"
          ],
          "title": "To",
          "type": "string"
        },
        "current_task": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Task"
        }
      },
      "required": [
        "seq",
        "ts",
        "session_id",
        "agent_id",
        "from",
        "to"
      ],
      "title": "AgentStateChanged",
      "type": "object"
    },
    "Change": {
